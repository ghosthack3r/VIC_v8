{
  "name": "vic-tactical-pc",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "npx vite",
    "dev:electron": "concurrently -k \"npm run dev:web\" \"wait-on tcp:5173 && node electron/launch.cjs development\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:full": "concurrently -k \"npm run dev:web\" \"wait-on tcp:5173 && node electron/launch.cjs development\"",
    "build": "npx vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "start": "node electron/launch.cjs production",
    "rebuild": "node scripts/rebuild-natives.cjs",
    "precheck": "node scripts/precheck.cjs",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test:setup": "node test/setup-scripts.test.cjs && node test/gemini-simulation.test.cjs && node test/logging-hooks.test.cjs && node test/logviewer.test.cjs && node test/vic-orb-state.test.cjs",
    "backend": "cd backend && python server.py",
    "backend:install": "pip install -r backend/requirements.txt"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
    "@react-three/drei": "^9.99.0",
    "@react-three/fiber": "^8.15.16",
    "@types/three": "^0.160.0",
    "@emotion/react": "^11.13.3",
    "clsx": "^2.1.0",
    "find-process": "^1.4.7",
    "framer-motion": "^11.5.4",
    "google-auth-library": "^10.6.2",
    "lucide-react": "0.522.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.4",
    "systeminformation": "^5.21.20",
    "tailwind-merge": "^2.2.0",
    "three": "^0.160.0",
    "tree-kill": "^1.2.2",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "node-window-manager": "^2.2.4",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "latest",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "electron": "^28.2.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "wait-on": "^7.2.0"
  }
}

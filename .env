# Copy to .env and fill in local values. Never commit .env.

# REQUIRED
# Google Gemini API key for ADA voice assistant, CAD agent, and web agent.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=yAQ.Ab8RN6KJdUrb4tGx2ExOzkxwoZ0Ce6bm67Ym55N4aITrPU_ZrA

# NAVIGATION (optional)
# Google Maps JavaScript API key, required for the NAV screen.
# Create at https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Places API, Directions API.
VITE_GOOGLE_MAPS_API_KEY=AIzaSyDjdYFwASndW8INBPlggklVVwwOMX1a5lo

# OBD-II (optional)
# ELM327 serial port. Windows examples: COM3, COM4. Linux example: /dev/ttyUSB0.
# Leave empty to select at runtime from the Diagnostics screen.
VIC_OBD_PORT=
VIC_OBD_BAUD=38400

# ELECTRON
# Set to 0 to launch maximized windowed instead of fullscreen.
VIC_FULLSCREEN=1

# VERTEX AI (optional, for production Gemini Live)
GOOGLE_CLOUD_PROJECT=gen-lang-client-0254325382
GOOGLE_CLOUD_LOCATION=us-central1
